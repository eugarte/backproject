# Environment Configuration
NODE_ENV=development
PORT=3003

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=msnotificaciones

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Notifications Service

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# WebSocket
WS_CORS_ORIGIN=*

# mssistemas Integration
MSSISTEMAS_URL=http://localhost:3001
MSSISTEMAS_API_KEY=your-api-key-here
SERVICE_NAME=msnotificaciones
SERVICE_VERSION=1.0.0
SERVICE_BASE_URL=http://localhost:3003
HEARTBEAT_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
